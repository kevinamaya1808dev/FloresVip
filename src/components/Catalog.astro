---
// src/components/Catalog.astro
import ProductCard from './ui/ProductCard.astro';

const productos = [
  {
    name: "Amanecer Pastel",
    category: "Ramos",
    price: "850",
    description: "Una mezcla delicada de rosas rosa empolvado y peonías blancas.",
    image: "https://images.unsplash.com/photo-1562690868-60bbe7293e94?q=80&w=800&auto=format&fit=crop"
  },
  {
    name: "Bosque Místico",
    category: "Arreglos",
    price: "1,200",
    description: "Diseño minimalista con eucalipto, cardos y flores silvestres verdes.",
    image: "https://images.unsplash.com/photo-1526047932273-341f2a7631f9?q=80&w=800&auto=format&fit=crop"
  },
 {
    name: "Suscripción Pétalo",
    category: "Suscripciones",
    price: "550",
    description: "Flores frescas de temporada entregadas en la puerta de tu casa cada semana.",
    // CAMBIA ESTA LÍNEA ESPECÍFICA CON LA NUEVA URL:
   image: "https://images.pexels.com/photos/4094504/pexels-photo-4094504.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Eternidad Blanca",
    category: "Bodas",
    price: "2,500",
    description: "El ramo de novia perfecto con orquídeas y lirios de la más alta calidad.",
    image: "https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=800&auto=format&fit=crop"
  }
];
---

<section id="catalogo" class="py-24 px-6 md:px-12 bg-petalo-cream">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-petalo-moss font-medium tracking-[0.2em] text-xs uppercase">Nuestra Colección</span>
      <h2 class="font-serif text-4xl md:text-5xl text-petalo-dark mt-2">Arreglos Exclusivos</h2>
      <div class="w-20 h-1 bg-petalo-rose mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {productos.map(producto => (
        <ProductCard {...producto} />
      ))}
    </div>
    
    <div class="text-center mt-16">
      <button class="border-b-2 border-petalo-moss text-petalo-moss font-semibold py-2 hover:text-petalo-dark hover:border-petalo-dark transition-all">
        Ver todo el catálogo
      </button>
    </div>
  </div>
</section>