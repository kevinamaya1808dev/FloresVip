---
// QuoteForm.astro
---
<section id="cotizar" class="py-24 px-6 md:px-12 bg-petalo-cream/50">
  <div class="max-w-5xl mx-auto bg-white rounded-petalo shadow-2xl overflow-hidden flex flex-col md:flex-row border border-petalo-moss/10">
    
    <div class="md:w-1/3 bg-petalo-moss p-12 text-white flex flex-col justify-between">
      <div>
        <h2 class="font-serif text-3xl mb-6">Cotiza tu Evento</h2>
        <p class="text-white/80 font-light text-sm leading-relaxed mb-8">
          Desde bodas íntimas hasta grandes celebraciones, nuestro equipo diseñará la atmósfera perfecta para ti.
        </p>
      </div>
      <div class="space-y-4 text-xs tracking-widest uppercase font-bold">
        <p class="flex items-center gap-3"><span class="text-petalo-rose">●</span> Respuesta en 24h</p>
        <p class="flex items-center gap-3"><span class="text-petalo-rose">●</span> Asesoría personalizada</p>
      </div>
    </div>

    <form class="md:w-2/3 p-8 md:p-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="flex flex-col gap-2">
        <label class="text-[10px] uppercase font-bold text-petalo-dark/50 tracking-widest">Nombre Completo</label>
        <input type="text" class="border-b border-petalo-moss/20 py-2 focus:border-petalo-rose outline-none transition-colors" placeholder="Tu nombre" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-[10px] uppercase font-bold text-petalo-dark/50 tracking-widest">Correo Electrónico</label>
        <input type="email" class="border-b border-petalo-moss/20 py-2 focus:border-petalo-rose outline-none transition-colors" placeholder="email@ejemplo.com" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-[10px] uppercase font-bold text-petalo-dark/50 tracking-widest">Tipo de Evento</label>
        <select class="border-b border-petalo-moss/20 py-2 focus:border-petalo-rose outline-none transition-colors bg-transparent">
          <option>Boda</option>
          <option>Aniversario</option>
          <option>Evento Corporativo</option>
          <option>Otro</option>
        </select>
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-[10px] uppercase font-bold text-petalo-dark/50 tracking-widest">Fecha Estimada</label>
        <input type="date" class="border-b border-petalo-moss/20 py-2 focus:border-petalo-rose outline-none transition-colors" />
      </div>
      <div class="md:col-span-2 flex flex-col gap-2 mt-4">
        <label class="text-[10px] uppercase font-bold text-petalo-dark/50 tracking-widest">Detalles del Pedido</label>
        <textarea rows="3" class="border border-petalo-moss/10 rounded-md p-4 focus:border-petalo-rose outline-none transition-colors" placeholder="Cuéntanos más sobre tus flores ideales..."></textarea>
      </div>
      <button class="md:col-span-2 bg-petalo-dark text-white py-5 rounded-petalo font-bold uppercase text-xs tracking-[0.2em] hover:bg-petalo-moss transition-all mt-4">
        Enviar Solicitud de Cotización
      </button>
    </form>
  </div>
</section>