---
// src/components/Services.astro

const servicios = [
  {
    title: "Arreglos Personalizados",
    description: "Diseñamos ramos únicos basados en tus flores favoritas y el mensaje que deseas transmitir.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>`
  },
  {
    title: "Decoración de Eventos",
    description: "Transformamos espacios para bodas, aniversarios y eventos corporativos con una estética de lujo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`
  },
  {
    title: "Suscripciones Mensuales",
    description: "Recibe flores frescas en tu hogar u oficina semanalmente para mantener la frescura siempre presente.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3Z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5Z"/><path d="m2 2 8.8 8.8"/><path d="M9.2 14.8 12 12"/></svg>`
  }
];
---

<section id="servicios" class="py-24 px-6 md:px-12 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-petalo-moss font-medium tracking-[0.2em] text-xs uppercase italic">Experiencia Pétalo</span>
      <h2 class="font-serif text-4xl md:text-5xl text-petalo-dark mt-2">Nuestros Servicios Profesionales</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {servicios.map((servicio) => (
        <div class="group p-8 rounded-petalo border border-petalo-moss/10 hover:border-petalo-rose hover:shadow-xl transition-all duration-500 bg-petalo-cream/30">
          <div class="w-14 h-14 bg-petalo-moss/10 text-petalo-moss rounded-full flex items-center justify-center mb-6 group-hover:bg-petalo-rose group-hover:text-white transition-colors duration-500">
            <Fragment set:html={servicio.icon} />
          </div>
          
          <h3 class="font-serif text-2xl text-petalo-dark mb-4">{servicio.title}</h3>
          <p class="text-petalo-dark/70 leading-relaxed text-sm md:text-base">
            {servicio.description}
          </p>
          
          <div class="mt-8">
            <a href="#cotizar" class="text-xs font-bold uppercase tracking-widest text-petalo-moss group-hover:text-petalo-rose transition-colors flex items-center gap-2">
              Saber más <span>→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>