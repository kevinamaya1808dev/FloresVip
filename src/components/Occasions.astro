---
// src/components/Occasions.astro

const ocasiones = [
  {
    title: "Aniversario",
    image: "https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&q=80&w=1000",
    link: "#",
    gridClass: "md:col-span-1"
  },
  {
    title: "Bodas",
    image: "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&q=80&w=1000",
    link: "#",
    gridClass: "md:col-span-1"
  },
  {
    title: "Cumpleaños",
    image: "https://images.unsplash.com/photo-1496062031456-07b8f162a322?q=80&w=1000&auto=format&fit=crop",
    link: "#",
    gridClass: "md:col-span-1"
  }
];
---

<section id="ocasiones" class="py-24 px-6 md:px-12 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <div class="max-w-xl">
        <span class="text-petalo-moss font-medium tracking-[0.2em] text-xs uppercase italic">Momentos Especiales</span>
        <h2 class="font-serif text-4xl md:text-5xl text-petalo-dark mt-2">Encuentra el detalle perfecto por ocasión</h2>
      </div>
      <p class="text-petalo-dark/60 max-w-xs text-sm pb-2">
        Seleccionamos las mejores variedades para que tu mensaje llegue directo al corazón.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 h-[600px] md:h-[500px]">
      {ocasiones.map((ocasion) => (
        <a 
          href={ocasion.link} 
          class={`relative group overflow-hidden rounded-petalo block h-full shadow-lg ${ocasion.gridClass}`}
        >
          <img 
            src={ocasion.image} 
            alt={ocasion.title} 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
          />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-opacity duration-500 group-hover:opacity-90"></div>

          <div class="absolute inset-0 flex flex-col justify-end p-8 text-white">
            <h3 class="font-serif text-3xl mb-4 transform transition-transform duration-500 group-hover:-translate-y-2">
              {ocasion.title}
            </h3>
            
            <div class="overflow-hidden">
              <span class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase opacity-0 transform translate-y-10 transition-all duration-500 group-hover:opacity-100 group-hover:translate-y-0">
                Explorar <span class="text-petalo-rose">→</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>